generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ========================================
// Auth
// ========================================

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  areas          Area[]
  tasks          Task[]
  transactions   Transaction[]
  goals          FinancialGoal[]
  references     Reference[]
  contents       Content[]
  aiInsights     AiInsight[]
  calendarEvents CalendarEvent[]
  skillSources   SkillSource[]
  apiUsage       ApiUsage[]
  monitorTerms   MonitorTerm[]
  ideaFeed       IdeaFeed[]
  newsEvidence   NewsEvidence[]

  @@map("users")
}

// ========================================
// Áreas — entidade raiz de classificação
// ========================================

model Area {
  id          String   @id @default(cuid())
  name        String
  color       String   @default("#00D6AB")
  icon        String   @default("📁")
  description String?
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  taskAreas          TaskArea[]
  transactions       Transaction[]
  references         Reference[]
  contents           Content[]
  calendarEvents     CalendarEvent[]
  referenceAreas     ReferenceArea[]
  contentAreas       ContentArea[]
  calendarEventAreas CalendarEventArea[]

  @@index([userId])
  @@map("areas")
}

// ========================================
// Tarefas
// ========================================

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum Recurrence {
  NONE
  DAILY
  WEEKLY
  MONTHLY
}

model Task {
  id           String       @id @default(cuid())
  title        String
  description  String?
  notes        String?
  priority     TaskPriority @default(MEDIUM)
  status       TaskStatus   @default(TODO)
  dueDate      DateTime?
  estimatedMin Int?
  recurrence   Recurrence   @default(NONE)
  completedAt  DateTime?
  isArchived   Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  userId   String
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  areas    TaskArea[]
  subtasks Subtask[]

  @@index([userId, status])
  @@map("tasks")
}

model TaskArea {
  taskId String
  areaId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  area   Area   @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@id([taskId, areaId])
  @@map("task_areas")
}

model Subtask {
  id     String  @id @default(cuid())
  title  String
  done   Boolean @default(false)
  order  Int     @default(0)
  taskId String
  task   Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("subtasks")
}

// ========================================
// Financeiro
// ========================================

enum TransactionType {
  INCOME
  EXPENSE
}

enum PaymentMethod {
  PIX
  DEBIT
  CREDIT
  CASH
  OTHER
}

model Transaction {
  id          String          @id @default(cuid())
  type        TransactionType
  amount      Float
  description String
  category    String
  date        DateTime
  isFixed     Boolean         @default(false)
  payment     PaymentMethod   @default(PIX)
  notes       String?
  isArchived  Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  areaId String?
  area   Area?  @relation(fields: [areaId], references: [id])

  @@index([userId, date])
  @@index([userId, type])
  @@map("transactions")
}

model FinancialGoal {
  id            String    @id @default(cuid())
  name          String
  targetAmount  Float
  currentAmount Float     @default(0)
  deadline      DateTime?
  category      String    @default("reserva")
  isArchived    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("financial_goals")
}

// ========================================
// Estudos — Biblioteca de Referências
// ========================================

enum ReferenceType {
  VIDEO
  ARTICLE
  BLOG
  PODCAST
  DOCUMENT
  OTHER
}

enum ReferenceStatus {
  UNREAD
  READING
  READ
  ARCHIVED
}

enum ReferencePriority {
  HIGH
  NORMAL
  LOW
}

model Reference {
  id         String            @id @default(cuid())
  title      String
  url        String
  source     String?
  type       ReferenceType     @default(ARTICLE)
  status     ReferenceStatus   @default(UNREAD)
  priority   ReferencePriority @default(NORMAL)
  tags       String[]
  comments   String?
  highlights String[]
  aiSummary  String?
  readAt     DateTime?
  plannedDate DateTime?
  isArchived Boolean           @default(false)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  areaId String?
  area   Area?  @relation(fields: [areaId], references: [id])
  areas  ReferenceArea[]

  @@index([userId, status])
  @@index([userId, plannedDate])
  @@map("references")
}

model ReferenceArea {
  referenceId String
  areaId      String
  reference   Reference @relation(fields: [referenceId], references: [id], onDelete: Cascade)
  area        Area      @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@id([referenceId, areaId])
  @@map("reference_areas")
}

// ========================================
// Conteúdo — Pipeline de Produção
// ========================================

enum Platform {
  YOUTUBE
  INSTAGRAM
  TIKTOK
  TWITCH
  OTHER
}

enum ContentFormat {
  LONG_VIDEO
  SHORT
  REELS
  POST
  LIVE
  THREAD
}

enum ContentPhase {
  IDEATION
  ELABORATION
  BRIEFING
  EDITING_SENT
  PUBLISHED
  ARCHIVED
}

enum ContentSkill {
  SHORT_VIDEO
  LONG_VIDEO
  INSTAGRAM
  INSTAGRAM_REELS
  YOUTUBE_SHORTS
  YOUTUBE_VIDEO
  TIKTOK_VIDEO
}

model Content {
  id             String        @id @default(cuid())
  title          String
  platform       Platform      @default(YOUTUBE)
  format         ContentFormat @default(LONG_VIDEO)
  phase          ContentPhase  @default(IDEATION)
  rawVideoUrl    String?
  skill          ContentSkill?
  targetDuration Int?
  hook           String?
  script         String?
  ideaFeedId     String?
  tags           String[]
  thumbnailNotes String?
  research       String?
  titleOptions   String[]
  description    String?
  hashtags       String[]
  checklist      Json?
  plannedDate    DateTime?
  publishedAt    DateTime?
  publishedUrl   String?
  notes          String?
  isArchived     Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  userId  String
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  areaId  String?
  area    Area?          @relation(fields: [areaId], references: [id])
  areas   ContentArea[]
  metrics ContentMetrics?

  @@index([userId, phase])
  @@map("contents")
}

model ContentArea {
  contentId String
  areaId    String
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  area      Area    @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@id([contentId, areaId])
  @@map("content_areas")
}

model ContentMetrics {
  id            String  @id @default(cuid())
  views         Int?
  reach         Int?
  engagement    Float?
  ctr           Float?
  retention     Float?
  newFollowers  Int?
  directRevenue Float?
  notes         String?
  contentId     String  @unique
  content       Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@map("content_metrics")
}

// ========================================
// Calendário
// ========================================

enum EventType {
  MEETING
  ATA
  ACTION
  GENERAL
}

model CalendarEvent {
  id          String    @id @default(cuid())
  title       String
  type        EventType @default(GENERAL)
  date        DateTime
  endDate     DateTime?
  description String?
  location    String?
  attendees   String[]
  notes       String?
  isArchived  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  areaId String?
  area   Area?  @relation(fields: [areaId], references: [id])
  areas  CalendarEventArea[]

  @@index([userId, date])
  @@map("calendar_events")
}

model CalendarEventArea {
  calendarEventId String
  areaId          String
  calendarEvent   CalendarEvent @relation(fields: [calendarEventId], references: [id], onDelete: Cascade)
  area            Area          @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@id([calendarEventId, areaId])
  @@map("calendar_event_areas")
}

// ========================================
// API Usage — Tracking de uso e custos
// ========================================

model ApiUsage {
  id         String   @id @default(cuid())
  action     String
  model      String   @default("claude-sonnet-4-6")
  inputTokens  Int    @default(0)
  outputTokens Int    @default(0)
  costUsd    Float    @default(0)
  durationMs Int      @default(0)
  createdAt  DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, action])
  @@map("api_usage")
}

// ========================================
// Repositório de Ideias — Monitoramento e Feed
// ========================================

model MonitorTerm {
  id        String   @id @default(cuid())
  term      String
  intent    String?  // Foco/exclusões do usuário pro termo — guia a triagem
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("monitor_terms")
}

model IdeaFeed {
  id            String    @id @default(cuid())
  title         String
  summary       String
  angle         String?
  source        String?
  sourceUrl     String?
  publishedAt   DateTime?
  language      String?   @default("pt-BR")
  pioneerScore  Int?
  relevance     String?
  hook          String?
  term          String
  score         Int       @default(90)
  // Ancoragem em evidência real (research-first)
  evidenceId           String?
  evidence             NewsEvidence? @relation(fields: [evidenceId], references: [id], onDelete: SetNull)
  evidenceQuote        String?    // trecho verbatim da matéria primária
  supportingEvidenceIds String[] @default([]) // IDs de matérias de apoio (triangulação)
  // Viralidade / cobertura
  viralScore           Int?       // 0-100 de publishers × idiomas × recência
  publisherHosts       String[] @default([]) // hosts únicos (primário + apoios)
  hasInternationalCoverage Boolean @default(false)
  // Encaixe por plataforma (0-100 cada): pra priorizar qual formato usar
  platformFit          Json?      // { reels: number, shorts: number, long: number, tiktok: number }
  isUsed        Boolean   @default(false)
  isDiscarded   Boolean   @default(false)
  isFavorite    Boolean   @default(false)    // estrela — destaca ideias prioritárias
  createdAt     DateTime  @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, isUsed, isDiscarded])
  @@index([userId, publishedAt])
  @@index([evidenceId])
  @@map("idea_feed")
}

// ========================================
// News Evidence — Fase A do radar (captura real de matérias)
// ========================================

model NewsEvidence {
  id              String    @id @default(cuid())
  term            String    // qual termo monitorado capturou essa evidência
  url             String    // URL canônica da matéria
  title           String
  publishedAt     DateTime?
  summary         String    // resumo de 2-3 frases baseado no que foi FETCHED
  keyQuote        String?   // trecho verbatim marcante (10-40 palavras)
  sourceAuthority String    @default("UNKNOWN") // TIER_1 | TIER_2 | BLOG | AGGREGATOR | UNKNOWN
  language        String    @default("pt-BR")   // pt-BR | en | es
  relevanceScore  Int       @default(50)        // 0-100 — quão forte ancora no termo
  freshnessHours  Int?      // horas desde publicação (estimativa no momento da captura)
  processed       Boolean   @default(false)     // virou ideia?
  capturedAt      DateTime  @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  ideas IdeaFeed[]

  @@unique([userId, url])
  @@index([userId, capturedAt])
  @@index([userId, term, capturedAt])
  @@index([userId, processed])
  @@map("news_evidence")
}

// ========================================
// Skills — Fontes e contribuições do usuário
// ========================================

model SkillSource {
  id        String   @id @default(cuid())
  skillId   String   // SHORT_VIDEO, LONG_VIDEO, INSTAGRAM
  title     String
  url       String?
  content   String?  // insight, nota, ou resumo
  type      String   @default("source") // source, insight, link, note
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, skillId])
  @@map("skill_sources")
}

// ========================================
// Motor IA — Insights
// ========================================

model AiInsight {
  id        String   @id @default(cuid())
  module    String
  type      String
  content   String
  reaction  String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("ai_insights")
}
