generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================
// Auth
// ========================================

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks    Task[]
  studies  Study[]
  expenses Expense[]
  incomes  Income[]

  @@map("users")
}

// ========================================
// Tarefas
// ========================================

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  tags        String[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("tasks")
}

// ========================================
// Estudos
// ========================================

enum StudyStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  PAUSED
}

model Study {
  id          String      @id @default(cuid())
  title       String
  description String?
  category    String
  totalHours  Float       @default(0)
  doneHours   Float       @default(0)
  status      StudyStatus @default(NOT_STARTED)
  link        String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions  StudySession[]

  @@index([userId])
  @@map("studies")
}

model StudySession {
  id        String   @id @default(cuid())
  hours     Float
  note      String?
  date      DateTime @default(now())

  studyId String
  study   Study  @relation(fields: [studyId], references: [id], onDelete: Cascade)

  @@index([studyId])
  @@map("study_sessions")
}

// ========================================
// Financeiro
// ========================================

enum TransactionCategory {
  MORADIA
  ALIMENTACAO
  TRANSPORTE
  SAUDE
  EDUCACAO
  LAZER
  INVESTIMENTO
  SALARIO
  FREELANCE
  OUTROS
}

model Expense {
  id          String              @id @default(cuid())
  description String
  amount      Float
  category    TransactionCategory
  date        DateTime
  recurring   Boolean             @default(false)
  createdAt   DateTime            @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("expenses")
}

model Income {
  id          String              @id @default(cuid())
  description String
  amount      Float
  category    TransactionCategory
  date        DateTime
  recurring   Boolean             @default(false)
  createdAt   DateTime            @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("incomes")
}
