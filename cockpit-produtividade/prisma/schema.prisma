generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ========================================
// Auth
// ========================================

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  areas          Area[]
  tasks          Task[]
  transactions   Transaction[]
  goals          FinancialGoal[]
  references     Reference[]
  studies        Study[]
  studySessions  StudySession[]
  aiInsights     AiInsight[]
  calendarEvents CalendarEvent[]
  apiUsage       ApiUsage[]
  notes          Note[]
  contacts       Contact[]

  @@map("users")
}

// ========================================
// Áreas — entidade raiz de classificação
// ========================================

model Area {
  id          String   @id @default(cuid())
  name        String
  color       String   @default("#00D6AB")
  icon        String   @default("📁")
  description String?
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  taskAreas          TaskArea[]
  transactions       Transaction[]
  references         Reference[]
  studies            Study[]
  studyAreas         StudyArea[]
  calendarEvents     CalendarEvent[]
  referenceAreas     ReferenceArea[]
  calendarEventAreas CalendarEventArea[]
  noteAreas          NoteArea[]
  contacts           Contact[]

  @@index([userId])
  @@map("areas")
}

// ========================================
// Tarefas
// ========================================

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum Recurrence {
  NONE
  DAILY
  WEEKLY
  MONTHLY
}

model Task {
  id           String       @id @default(cuid())
  title        String
  description  String?
  notes        String?
  priority     TaskPriority @default(MEDIUM)
  status       TaskStatus   @default(TODO)
  dueDate      DateTime?
  estimatedMin Int?
  recurrence   Recurrence   @default(NONE)
  completedAt  DateTime?
  isArchived   Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  areas        TaskArea[]
  subtasks     Subtask[]
  linkedNotes  Note[]     @relation("TaskNotes")

  @@index([userId, status])
  @@map("tasks")
}

model TaskArea {
  taskId String
  areaId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  area   Area   @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@id([taskId, areaId])
  @@map("task_areas")
}

model Subtask {
  id     String  @id @default(cuid())
  title  String
  done   Boolean @default(false)
  order  Int     @default(0)
  taskId String
  task   Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("subtasks")
}

// ========================================
// Financeiro
// ========================================

enum TransactionType {
  INCOME
  EXPENSE
}

enum PaymentMethod {
  PIX
  DEBIT
  CREDIT
  CASH
  OTHER
}

model Transaction {
  id          String          @id @default(cuid())
  type        TransactionType
  amount      Float
  description String
  category    String
  date        DateTime
  isFixed     Boolean         @default(false)
  payment     PaymentMethod   @default(PIX)
  notes       String?
  isArchived  Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  areaId String?
  area   Area?   @relation(fields: [areaId], references: [id])

  @@index([userId, date])
  @@index([userId, type])
  @@map("transactions")
}

model FinancialGoal {
  id            String    @id @default(cuid())
  name          String
  targetAmount  Float
  currentAmount Float     @default(0)
  deadline      DateTime?
  category      String    @default("reserva")
  isArchived    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("financial_goals")
}

// ========================================
// Estudos — Biblioteca de Referências
// ========================================

enum ReferenceType {
  VIDEO
  ARTICLE
  BLOG
  PODCAST
  DOCUMENT
  OTHER
}

enum ReferenceStatus {
  UNREAD
  READING
  READ
  ARCHIVED
}

enum ReferencePriority {
  HIGH
  NORMAL
  LOW
}

model Reference {
  id          String            @id @default(cuid())
  title       String
  url         String
  source      String?
  type        ReferenceType     @default(ARTICLE)
  status      ReferenceStatus   @default(UNREAD)
  priority    ReferencePriority @default(NORMAL)
  tags        String[]
  comments    String?
  highlights  String[]
  aiSummary   String?
  readAt      DateTime?
  plannedDate DateTime?
  isArchived  Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  userId String
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  areaId String?
  area   Area?           @relation(fields: [areaId], references: [id])
  areas  ReferenceArea[]

  @@index([userId, status])
  @@index([userId, plannedDate])
  @@map("references")
}

model ReferenceArea {
  referenceId String
  areaId      String
  reference   Reference @relation(fields: [referenceId], references: [id], onDelete: Cascade)
  area        Area      @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@id([referenceId, areaId])
  @@map("reference_areas")
}

// ========================================
// Conteúdo — Pipeline de Produção
// ========================================

// ========================================
// Estudos — Projetos de Estudo (Studies)
// ========================================
// Representa um projeto/curso/livro/área de aprendizado em andamento.
// Contém múltiplas sessões (StudySession) registrando tempo dedicado.
// Complementa Reference (biblioteca de itens) com tracking de horas e estado.

enum StudyStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  PAUSED
}

model Study {
  id          String      @id @default(cuid())
  title       String
  description String?
  category    String
  link        String?
  totalHours  Float       @default(0)
  doneHours   Float       @default(0)
  status      StudyStatus @default(NOT_STARTED)
  isArchived  Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  userId   String
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  areaId   String?
  area     Area?          @relation(fields: [areaId], references: [id])
  areas    StudyArea[]
  sessions StudySession[]

  @@index([userId, status])
  @@map("studies")
}

model StudyArea {
  studyId String
  areaId  String
  study   Study  @relation(fields: [studyId], references: [id], onDelete: Cascade)
  area    Area   @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@id([studyId, areaId])
  @@map("study_areas")
}

model StudySession {
  id        String   @id @default(cuid())
  hours     Float
  note      String?
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  studyId String
  study   Study  @relation(fields: [studyId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([studyId, date])
  @@map("study_sessions")
}

// ========================================
// Calendário
// ========================================

enum EventType {
  MEETING
  ATA
  ACTION
  GENERAL
}

model CalendarEvent {
  id          String    @id @default(cuid())
  title       String
  type        EventType @default(GENERAL)
  date        DateTime
  endDate     DateTime?
  description String?
  location    String?
  attendees   String[]
  notes       String?
  isArchived  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  areaId      String?
  area        Area?               @relation(fields: [areaId], references: [id])
  areas       CalendarEventArea[]
  linkedNotes Note[]              @relation("EventNotes")

  @@index([userId, date])
  @@map("calendar_events")
}

model CalendarEventArea {
  calendarEventId String
  areaId          String
  calendarEvent   CalendarEvent @relation(fields: [calendarEventId], references: [id], onDelete: Cascade)
  area            Area          @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@id([calendarEventId, areaId])
  @@map("calendar_event_areas")
}

// ========================================
// API Usage — Tracking de uso e custos
// ========================================

model ApiUsage {
  id           String   @id @default(cuid())
  action       String
  model        String   @default("claude-sonnet-4-6")
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  costUsd      Float    @default(0)
  durationMs   Int      @default(0)
  createdAt    DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, action])
  @@map("api_usage")
}

// ========================================
// Notas — captura livre, journal, meeting notes, ideias
// ========================================
// É a peça que conecta áreas a pensamento bruto. Nasceu da deep research:
// PARA + AI auto-tag. Tudo que não é tarefa/evento/estudo cai aqui.
// type discrimina o uso (free/journal/meeting/idea/reference_summary).
// areaIds[] M2M = uma nota pode pertencer a várias áreas da vida.

enum NoteType {
  FREE
  JOURNAL
  MEETING
  IDEA
  REFERENCE_SUMMARY
}

model Note {
  id         String   @id @default(cuid())
  title      String?
  content    String
  type       NoteType @default(FREE)
  source     String?  // "telegram" | "manual" | "voice" | "meeting"
  date       DateTime @default(now())
  isPinned   Boolean  @default(false)
  isArchived Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  areas         NoteArea[]
  linkedTaskId  String?
  linkedTask    Task?          @relation("TaskNotes", fields: [linkedTaskId], references: [id], onDelete: SetNull)
  linkedEventId String?
  linkedEvent   CalendarEvent? @relation("EventNotes", fields: [linkedEventId], references: [id], onDelete: SetNull)
  contactId     String?
  contact       Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([userId, type])
  @@index([userId, contactId])
  @@map("notes")
}

model NoteArea {
  noteId String
  areaId String
  note   Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
  area   Area @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@id([noteId, areaId])
  @@map("note_areas")
}

// ========================================
// Contatos — base de clientes / parceiros / leads
// ========================================
// Âncora cross-entidade: notas do worker (e UI) podem linkar contactId.
// lastContactAt é atualizado automaticamente pelo router toda vez que
// uma nota é criada com este contato, viabilizando follow-up tracking.

model Contact {
  id            String    @id @default(cuid())
  name          String
  company       String?
  project       String?
  telegram      String?   // @handle (sem @ ou com — normalizar)
  twitter       String?   // @handle
  notes         String?   // observações livres
  lastContactAt DateTime?
  isArchived    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  areaId String?
  area   Area?   @relation(fields: [areaId], references: [id])
  linkedNotes Note[]

  @@index([userId, lastContactAt])
  @@index([userId, isArchived])
  @@map("contacts")
}

// ========================================
// Motor IA — Insights
// ========================================

model AiInsight {
  id        String   @id @default(cuid())
  module    String
  type      String
  content   String
  reaction  String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("ai_insights")
}
