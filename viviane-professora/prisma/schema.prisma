generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ========================================
// Auth
// ========================================

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  password     String
  // Contexto pedagógico — o perfil da professora
  schoolName   String? // Colégio Porto Seguro
  schoolUnit   String? // Portinho
  gradeLevel   String? // 3º ano Fundamental I
  teachingYear String? // 2026
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  students          Student[]
  observations      Observation[]
  reports           Report[]
  lessonPlans       LessonPlan[]
  activities        Activity[]
  communications    Communication[]
  corrections       Correction[]
  calendarEvents    CalendarEvent[]
  weeklyAssessments WeeklyAssessment[]
  assessments       MonthlyAssessment[]
  apiUsage          ApiUsage[]
  aiInsights        AiInsight[]

  @@map("users")
  }

// ========================================
// SKILL 1 — Alunos
// ========================================

model Student {
  id             String    @id @default(cuid())
  fullName       String
  nickname       String?
  birthDate      DateTime?
  photoUrl       String?
  // Contato
  guardian1Name  String?
  guardian1Phone String?
  guardian1Email String?
  guardian2Name  String?
  guardian2Phone String?
  guardian2Email String?
  // Perfil pedagógico
  learningStyle  String? // "visual", "auditivo", "cinestésico", "misto"
  strengths      String? // pontos fortes (texto livre)
  challenges     String? // dificuldades observadas
  specialNeeds   String? // TEA, TDAH, dislexia, altas habilidades, etc.
  medicalNotes   String? // alergias, medicamentos — sensível
  // Meta
  enrollmentId   String? // matrícula no Porto Seguro
  classroom      String? // 3º A, 3º B, etc.
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  observations      Observation[]
  reports           Report[]
  corrections       Correction[]
  communications    Communication[]
  weeklyAssessments WeeklyAssessment[]
  assessments       MonthlyAssessment[]

  @@index([userId, isActive])
  @@index([userId, classroom])
  @@map("students")
  }

// ========================================
// SKILL 2 — Observações diárias
// ========================================

enum ObservationCategory {
  BEHAVIOR // comportamento
  ACADEMIC // aprendizagem / desempenho
  SOCIAL // relacionamento com colegas
  EMOTIONAL // aspecto emocional
  HEALTH // saúde / bem-estar
  PARTICIPATION // engajamento em aula
  OTHER
  }

enum ObservationSentiment {
  POSITIVE
  NEUTRAL
  CONCERN
  URGENT
  }

model Observation {
  id         String               @id @default(cuid())
  category   ObservationCategory
  sentiment  ObservationSentiment @default(NEUTRAL)
  title      String
  note       String // texto livre — "hoje o João..."
  // Contexto
  subject    String? // matemática, português, ciências, etc.
  occurredAt DateTime             @default(now())
  // IA enrichment (preenchido depois)
  aiSummary  String?
  aiTags     String[]             @default([])
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
  @@index([studentId, occurredAt])
  @@index([userId, category])
  @@map("observations")
  }

// ========================================
// SKILL 3 — Relatórios descritivos
// ========================================

enum ReportPeriod {
  BIMESTER_1
  BIMESTER_2
  BIMESTER_3
  BIMESTER_4
  SEMESTER_1
  SEMESTER_2
  ANNUAL
  CUSTOM
  }

enum ReportStatus {
  DRAFT
  REVIEWED
  FINAL
  }

model Report {
  id                String       @id @default(cuid())
  period            ReportPeriod
  periodLabel       String? // "3º bim 2026"
  status            ReportStatus @default(DRAFT)
  // Corpo do relatório (seções que a professora revisa)
  socioEmotional    String? // desenvolvimento sócio-emocional
  academic          String? // aproveitamento acadêmico
  language          String? // língua portuguesa
  math              String? // matemática
  science           String? // ciências / natureza
  socialStudies     String? // história/geografia
  arts              String? // artes
  physicalEd        String? // educação física
  participation     String? // participação / autonomia
  conclusion        String? // conclusão / recomendações
  // IA
  sourcedFromObsIds String[]     @default([]) // IDs das observações usadas
  generatedBy       String? // "ai" | "manual" | "ai_edited"
  // Meta
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([studentId, period])
  @@map("reports")
  }

// ========================================
// SKILL 4 — Planos de aula
// ========================================

enum LessonPlanStatus {
  PLANNED
  TAUGHT
  REVIEWED
  }

model LessonPlan {
  id          String           @id @default(cuid())
  title       String
  subject     String // matemática, português, ciências, artes, etc.
  date        DateTime
  duration    Int? // em minutos
  // Conteúdo pedagógico
  bnccCodes   String[]         @default([]) // EF03LP01, EF03MA02, etc.
  objectives  String // o que o aluno deve aprender
  skills      String? // habilidades desenvolvidas
  content     String? // conteúdo/assunto da aula
  // Metodologia
  methodology String? // como vai ensinar
  materials   String? // materiais necessários
  activities  String? // passo a passo da aula
  assessment  String? // como vai avaliar
  homework    String? // dever de casa
  // Diferenciação
  adaptations String? // adaptações para alunos específicos
  // IA metadata
  generatedBy String? // "ai" | "manual" | "ai_edited"
  citations   Json? // [{ source: "BNCC", ref: "EF03LP01", url: "..." }]
  status      LessonPlanStatus @default(PLANNED)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  activities_rel Activity[]

  @@index([userId, date])
  @@index([userId, subject])
  @@map("lesson_plans")
  }

// ========================================
// SKILL 5 — Atividades / exercícios
// ========================================

enum ActivityType {
  EXERCISE // lista de exercícios
  ASSESSMENT // prova / avaliação
  PROJECT // projeto
  GAME // jogo / dinâmica
  READING // leitura
  WRITING // produção textual
  OTHER
  }

enum ActivityDifficulty {
  EASY
  MEDIUM
  HARD
  }

model Activity {
  id            String             @id @default(cuid())
  title         String
  type          ActivityType       @default(EXERCISE)
  subject       String
  difficulty    ActivityDifficulty @default(MEDIUM)
  // Conteúdo
  instructions  String // enunciado geral
  items         Json? // lista de questões/itens em JSON
  bnccCodes     String[]           @default([])
  estimatedMin  Int?
  // Arquivos
  attachmentUrl String? // PDF ou imagem
  answerKey     String? // gabarito
  // IA
  generatedBy   String? // "ai" | "manual" | "ai_edited"
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonPlanId String?
  lessonPlan   LessonPlan? @relation(fields: [lessonPlanId], references: [id], onDelete: SetNull)

  @@index([userId, subject])
  @@index([userId, type])
  @@map("activities")
  }

// ========================================
// SKILL 6 — Comunicação com pais
// ========================================

enum CommunicationType {
  NOTE // bilhete na agenda
  EMAIL
  WHATSAPP
  MEETING // ata de reunião
  PHONE_CALL
  OTHER
  }

enum CommunicationStatus {
  DRAFT
  SENT
  ANSWERED
  FOLLOWUP_NEEDED
  }

model Communication {
  id          String              @id @default(cuid())
  type        CommunicationType
  subject     String
  body        String
  // Destinatários
  toName      String? // nome do responsável
  toContact   String? // email/phone
  // IA
  tone        String? // "formal", "empático", "informativo", "alerta"
  generatedBy String? // "ai" | "manual" | "ai_edited"
  status      CommunicationStatus @default(DRAFT)
  sentAt      DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentId String?
  student   Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([studentId])
  @@map("communications")
  }

// ========================================
// SKILL 7 — Correções
// ========================================

enum CorrectionStatus {
  PENDING
  IN_REVIEW
  DONE
  RETURNED // devolvida ao aluno
  }

model Correction {
  id           String           @id @default(cuid())
  title        String
  subject      String
  activityType String? // "prova", "lista", "caderno", "redação"
  // Entrada
  imageUrl     String? // foto do caderno / atividade
  pdfUrl       String?
  rubric       String? // critérios de correção
  // Resultado
  grade        String? // nota ou conceito (A, B, satisfatório)
  feedback     String? // feedback individualizado
  strengths    String? // pontos fortes identificados
  improvements String? // o que precisa melhorar
  // IA
  aiSuggestion String? // sugestão bruta da IA
  generatedBy  String? // "ai" | "manual" | "ai_edited"
  status       CorrectionStatus @default(PENDING)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([studentId])
  @@map("corrections")
  }

// ========================================
// SKILL 8 — Calendário pedagógico
// ========================================

enum CalendarEventType {
  CLASS // aula
  MEETING // reunião pedagógica
  PARENT_MEETING // reunião com pais
  ASSESSMENT // prova / avaliação
  EVENT // evento escolar (feira, festa)
  HOLIDAY // feriado / recesso
  DEADLINE // prazo (entregar relatório)
  PERSONAL
  OTHER
  }

model CalendarEvent {
  id          String            @id @default(cuid())
  title       String
  type        CalendarEventType @default(CLASS)
  startAt     DateTime
  endAt       DateTime?
  allDay      Boolean           @default(false)
  location    String?
  description String?
  notes       String?
  // Recorrência simples
  recurrence  String? // "NONE", "DAILY", "WEEKLY", "MONTHLY"
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startAt])
  @@index([userId, type])
  @@map("calendar_events")
  }

// ========================================
// SKILL 9 — Avaliações mensais (radar)
// ========================================

model WeeklyAssessment {
  id            String   @id @default(cuid())
  referenceWeek DateTime // segunda-feira da semana
  label         String?  // "Semana de 06/04" (opcional)
  // 8 eixos (1-5)
  alimentacao           Int @default(3)
  comportamento         Int @default(3)
  relacoesInterpessoais Int @default(3)
  participacao          Int @default(3)
  autonomia             Int @default(3)
  aprendizagem          Int @default(3)
  emocional             Int @default(3)
  higiene               Int @default(3)
  // Notas curtas por eixo (semanal — rápido)
  alimentacaoNote           String?
  comportamentoNote         String?
  relacoesInterpessoaisNote String?
  participacaoNote          String?
  autonomiaNote             String?
  aprendizagemNote          String?
  emocionalNote             String?
  higieneNote               String?
  // Destaque da semana
  highlight String?
  concerns  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, referenceWeek])
  @@index([userId, referenceWeek])
  @@map("weekly_assessments")
  }

model MonthlyAssessment {
  id             String   @id @default(cuid())
  referenceMonth DateTime // primeiro dia do mês (ex: 2026-03-01)
  label          String? // "Reunião de Março 2026"
  // 8 eixos (1-5)
  alimentacao           Int @default(3)
  comportamento         Int @default(3)
  relacoesInterpessoais Int @default(3)
  participacao          Int @default(3)
  autonomia             Int @default(3)
  aprendizagem          Int @default(3)
  emocional             Int @default(3)
  higiene               Int @default(3)
  // Notas por eixo (opcional)
  alimentacaoNote           String?
  comportamentoNote         String?
  relacoesInterpessoaisNote String?
  participacaoNote          String?
  autonomiaNote             String?
  aprendizagemNote          String?
  emocionalNote             String?
  higieneNote               String?
  // Notas gerais
  overallNotes String?
  nextSteps    String?
  // Consolidação
  sourcedFromWeekIds String[] @default([]) // IDs das WeeklyAssessment usadas
  sourcedFromObsIds  String[] @default([]) // IDs das observações cruzadas
  generatedBy        String?  // "ai" | "manual" | "ai_edited"
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, referenceMonth])
  @@index([userId, referenceMonth])
  @@map("monthly_assessments")
  }

// ========================================
// Infraestrutura — IA / observabilidade
// ========================================

model ApiUsage {
  id                  String   @id @default(cuid())
  action              String // "generate_report", "correct_homework", "draft_communication", etc.
  model               String // "claude-opus-4-7"
  inputTokens         Int
  outputTokens        Int
  cacheReadTokens     Int      @default(0)
  cacheCreationTokens Int      @default(0)
  costUsd             Float
  durationMs          Int
  createdAt           DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, action])
  @@map("api_usage")
  }

model AiInsight {
  id        String   @id @default(cuid())
  module    String // "student", "weekly", "report", etc.
  type      String // "summary", "insight", "warning"
  content   String
  reaction  String? // emoji / feedback
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("ai_insights")
  }
